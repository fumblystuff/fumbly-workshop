  },
  "bugs": {
    "url": "https://github.com/johnwargo/album-cube/issues"
  },
  "main": "index.js",
  "type": "module",
  "scripts": {
    "clean": "rimraf _site",
    "build:eleventy": "eleventy",
    "watch:eleventy": "eleventy --serve --quiet",
