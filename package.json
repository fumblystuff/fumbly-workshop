    "@11ty/eleventy-navigation": "^1.0.5",
    "eleventy-generate-category-pages": "^0.1.4",
    "eleventy-plugin-date": "^1.0.0",
    "eleventy-plugin-markdown-page-links": "^0.0.17",
    "html-minifier": "^4.0.0",
    "markdown-it": "^14.1.0",
    "markdown-it-attrs": "^4.3.1",
    "netlify-plugin-cache": "^1.0.3",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.2"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
