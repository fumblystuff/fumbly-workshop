title: Article Categories
eleventyNavigation:
  key: Categories
  parent: Articles
  order: 2
---

{% assign categories = categoryData | sort %}

<p>View all posts for a particular category by clicking on one of the categories listed below. There are {{ categories.length }} categories on the site today.</p>

{% if categories.length > 0 %}
  <table class="categories">
    {% tablerow catData in categories cols:2 %}
       <h4>
          <a href="/categories/{{ catData.category | slugify }}/">{{ catData.category }}</a>
        </h4>
        {{ catData.count }} Post{%- if catData.count > 1 %}s{% endif %}
        {% if catData.description.length > 0 %}
          | {{ catData.description }}
        {% endif %}
    {% endtablerow %}
  </table>  
{% else %}
    <p>No category data to display (this should never happen).</p>
{% endif %} 
